# VibeUncle Project Environment Variables
# Copy this file to .env.local and fill in the values

# ===================
# N8N Integration
# ===================
N8N_WEBHOOK_URL=https://api.vibeuncle.com/webhook/greatpath-show
# N8N_SEARCH_URL=https://api.vibeuncle.com/webhook/greatpath-show-search
# N8N_GET_URL=https://api.vibeuncle.com/webhook/greatpath-show-get

# ===================
# Cloudflare R2 Storage (required for async job pattern)
# ===================
R2_PUBLIC_URL=https://greatpath-show-assets.vibeuncle.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://greatpath-show-assets.vibeuncle.com

# ===================
# Google Sheets (for data/stats)
# ===================
# NEXT_PUBLIC_GOOGLE_SHEETS_ID=your_sheet_id
# NEXT_PUBLIC_GOOGLE_SHEETS_PUBLISHED_URL=https://docs.google.com/spreadsheets/d/e/[ID]/pub?output=csv

# ===================
# Supabase (optional - uncomment if using database)
# ===================
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===================
# Activities Slideshow (greatpath-greatbusiness.com public data feed)
# Defaults are baked into lib/activities.ts — only set these to override.
# ===================
# ACTIVITIES_SUPABASE_URL=https://zcaqgvxmhrhzhzxrjsnj.supabase.co
# ACTIVITIES_SUPABASE_ANON_KEY=eyJ...

# ===================
# Application Settings
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_ACCESS_CODE=optional_access_code

# ===================
# Development Flags
# ===================
# NEXT_PUBLIC_MOCK_DATA=false
